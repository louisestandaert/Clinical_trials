<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="330.0" prefWidth="580.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.RemoveHospitalFromTrialController">
   <children>
      <Label layoutX="135.0" layoutY="31.0" text="REMOVE HOSPITAL FROM TRIAL" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="20.0" /></font>
      </Label>
      <TextField fx:id="hospitalIdField" layoutX="215.0" layoutY="91.0" promptText="Hospital ID" />
      <TextField fx:id="trialIdField" layoutX="215.0" layoutY="132.0" promptText="Trial ID" />
      <Button fx:id="removeButton" layoutX="225.0" layoutY="184.0" mnemonicParsing="false" onAction="#handleRemoveHospitalFromTrial" prefWidth="130.0" style="-fx-background-color: #B45151; -fx-text-fill: white;" text="REMOVE" />
      <Label fx:id="messageLabel" layoutX="90.0" layoutY="231.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true" />
      <Button layoutX="250.0" layoutY="270.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" prefWidth="90.0" text="GO BACK" />
   </children>
</AnchorPane>
