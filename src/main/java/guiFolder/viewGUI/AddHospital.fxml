<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="360.0" prefWidth="580.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.AddHospitalController">
   <children>
      <Label layoutX="220.0" layoutY="31.0" text="ADD HOSPITAL" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="20.0" /></font>
      </Label>
      <TextField fx:id="hospitalIdField" layoutX="215.0" layoutY="91.0" promptText="Hospital ID" />
      <TextField fx:id="hospitalNameField" layoutX="215.0" layoutY="132.0" promptText="Hospital Name" />
      <TextField fx:id="hospitalCityField" layoutX="215.0" layoutY="173.0" promptText="Hospital City" />
      <Button fx:id="addHospitalButton" layoutX="220.0" layoutY="226.0" mnemonicParsing="false" onAction="#handleAddHospital" prefWidth="100.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="ADD" />
      <Button layoutX="338.0" layoutY="226.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" prefWidth="90.0" text="GO BACK" />
      <Label fx:id="messageLabel" layoutX="90.0" layoutY="288.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true" />
   </children>
</AnchorPane>
