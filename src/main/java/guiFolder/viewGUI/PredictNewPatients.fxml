<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="350.0" prefWidth="580.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.PredictNewPatientsController">
   <children>
      <Label layoutX="153.0" layoutY="31.0" text="PREDICT NEW PATIENTS" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="20.0" /></font>
      </Label>
      <TextField fx:id="trialIdField" layoutX="215.0" layoutY="92.0" promptText="Trial ID" />
      <Button fx:id="predictButton" layoutX="230.0" layoutY="143.0" mnemonicParsing="false" onAction="#handlePredictNewPatients" prefWidth="120.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="PREDICT" />
      <Label fx:id="resultLabel" layoutX="90.0" layoutY="200.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true">
         <font><Font size="16.0" /></font>
      </Label>
      <Label fx:id="messageLabel" layoutX="90.0" layoutY="243.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true" />
      <Button fx:id="backButton" layoutX="250.0" layoutY="292.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" prefWidth="90.0" text="GO BACK" />
   </children>
</AnchorPane>
