<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.CompareTrialResultsController">
   <children>
      <Label layoutX="174.0" layoutY="26.0" text="COMPARE TRIAL RESULTS" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="21.0" /></font>
      </Label>
      <TextField fx:id="trialIdField" layoutX="176.0" layoutY="83.0" promptText="Trial ID" />
      <Button fx:id="compareButton" layoutX="348.0" layoutY="83.0" mnemonicParsing="false" onAction="#handleCompareResults" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" prefWidth="90.0" text="COMPARE" />
      <TextArea fx:id="resultArea" layoutX="82.0" layoutY="135.0" prefHeight="150.0" prefWidth="436.0" wrapText="true" />
      <Label fx:id="messageLabel" layoutX="100.0" layoutY="304.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true" />
      <Button fx:id="backButton" layoutX="258.0" layoutY="340.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" prefWidth="90.0" text="GO BACK" />
   </children>
</AnchorPane>
