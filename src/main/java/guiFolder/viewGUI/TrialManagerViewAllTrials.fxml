<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="420.0" prefWidth="620.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.TrialManagerViewAllTrialsController">
   <children>
      <Label layoutX="224.0" layoutY="24.0" text="ALL TRIALS" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="22.0" /></font>
      </Label>
      <Button fx:id="refreshButton" layoutX="250.0" layoutY="65.0" mnemonicParsing="false" onAction="#handleRefreshTrials" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" prefWidth="90.0" text="REFRESH" />
      <TextArea fx:id="trialsArea" layoutX="66.0" layoutY="109.0" prefHeight="233.0" prefWidth="488.0" wrapText="true" />
      <Label fx:id="messageLabel" layoutX="110.0" layoutY="352.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true" />
      <Button fx:id="backButton" layoutX="266.0" layoutY="381.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" prefWidth="90.0" text="GO BACK" />
   </children>
</AnchorPane>
