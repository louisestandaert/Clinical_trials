<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="430.0" prefWidth="620.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.CreateTrialController">
   <children>
      <Label layoutX="236.0" layoutY="25.0" text="CREATE TRIAL" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="22.0" /></font>
      </Label>
      <TextField fx:id="trialIdField" layoutX="226.0" layoutY="79.0" promptText="Trial ID" />
      <TextField fx:id="trialNameField" layoutX="226.0" layoutY="120.0" promptText="Trial Name" />
      <TextField fx:id="startingDateField" layoutX="226.0" layoutY="161.0" promptText="Starting Date YYYY-MM-DD" />
      <TextField fx:id="durationDaysField" layoutX="226.0" layoutY="202.0" promptText="Duration Days" />
      <TextField fx:id="budgetField" layoutX="226.0" layoutY="243.0" promptText="Budget" />
      <TextField fx:id="targetPatientsField" layoutX="226.0" layoutY="284.0" promptText="Target Patients" />
      <Button fx:id="createTrialButton" layoutX="217.0" layoutY="335.0" mnemonicParsing="false" onAction="#handleCreateTrial" prefWidth="100.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="CREATE" />
      <Button layoutX="339.0" layoutY="335.0" mnemonicParsing="false" onAction="#handleBack" prefWidth="80.0" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" text="GO BACK" />
      <Label fx:id="messageLabel" layoutX="110.0" layoutY="383.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true" />
   </children>
</AnchorPane>
