<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="420.0" prefWidth="620.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.TrialManagerViewTrialDetailsController">
   <children>
      <Label layoutX="199.0" layoutY="24.0" text="TRIAL DETAILS" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="22.0" /></font>
      </Label>
      <TextField fx:id="trialIdField" layoutX="206.0" layoutY="73.0" promptText="Trial ID" />
      <Button fx:id="searchButton" layoutX="373.0" layoutY="73.0" mnemonicParsing="false" onAction="#handleSearchTrial" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" prefWidth="90.0" text="SEARCH" />
      <TextArea fx:id="trialDetailsArea" layoutX="66.0" layoutY="120.0" prefHeight="220.0" prefWidth="488.0" wrapText="true" />
      <Label fx:id="messageLabel" layoutX="110.0" layoutY="350.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true" />
      <Button fx:id="backButton" layoutX="266.0" layoutY="381.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" prefWidth="90.0" text="GO BACK" />
   </children>
</AnchorPane>
