<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="760.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.XmlToolsController">
   <children>
      <Label layoutX="318.0" layoutY="22.0" text="XML TOOLS" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="22.0" /></font>
      </Label>
      <Button layoutX="49.0" layoutY="79.0" mnemonicParsing="false" onAction="#handleExportDatabase" prefWidth="180.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="EXPORT DATABASE" />
      <Button layoutX="49.0" layoutY="119.0" mnemonicParsing="false" onAction="#handleImportDatabase" prefWidth="180.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="IMPORT DATABASE" />
      <Button layoutX="49.0" layoutY="159.0" mnemonicParsing="false" onAction="#handleTransformToHtml" prefWidth="180.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="TRANSFORM TO HTML" />

      <TextField fx:id="patientIdField" layoutX="280.0" layoutY="79.0" promptText="Patient ID" />
      <Button layoutX="449.0" layoutY="79.0" mnemonicParsing="false" onAction="#handleExportPatient" prefWidth="140.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="EXPORT PATIENT" />
      <TextField fx:id="trialIdField" layoutX="280.0" layoutY="119.0" promptText="Trial ID" />
      <Button layoutX="449.0" layoutY="119.0" mnemonicParsing="false" onAction="#handleExportTrial" prefWidth="140.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="EXPORT TRIAL" />

      <TextField fx:id="importPathField" layoutX="280.0" layoutY="176.0" prefWidth="310.0" promptText="XML file path to import" />
      <Button layoutX="280.0" layoutY="216.0" mnemonicParsing="false" onAction="#handleImportPatient" prefWidth="145.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="IMPORT PATIENT" />
      <Button layoutX="445.0" layoutY="216.0" mnemonicParsing="false" onAction="#handleImportTrial" prefWidth="145.0" style="-fx-background-color: #2F7F95; -fx-text-fill: white;" text="IMPORT TRIAL" />

      <TextArea fx:id="outputArea" layoutX="49.0" layoutY="273.0" prefHeight="130.0" prefWidth="660.0" wrapText="true" />
      <Label fx:id="messageLabel" layoutX="80.0" layoutY="418.0" prefWidth="600.0" textAlignment="CENTER" wrapText="true" />
      <Button fx:id="backButton" layoutX="333.0" layoutY="453.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" prefWidth="90.0" text="GO BACK" />
   </children>
</AnchorPane>
