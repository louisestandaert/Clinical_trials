<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="330.0" prefWidth="560.0" style="-fx-background-color: #EAF4F8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="guiFolder.controllerGUI.RemoveDoctorController">
   <children>
      <Label layoutX="201.0" layoutY="31.0" text="REMOVE DOCTOR" textFill="#1f4652">
         <font><Font name="Apple SD Gothic Neo Bold" size="20.0" /></font>
      </Label>
      <TextField fx:id="doctorIdField" layoutX="205.0" layoutY="100.0" promptText="Doctor ID" />
      <Button fx:id="removeButton" layoutX="215.0" layoutY="155.0" mnemonicParsing="false" onAction="#handleRemoveDoctor" prefWidth="130.0" style="-fx-background-color: #B45151; -fx-text-fill: white;" text="REMOVE" />
      <Label fx:id="messageLabel" layoutX="80.0" layoutY="210.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true" />
      <Button layoutX="240.0" layoutY="260.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #6A7D84; -fx-text-fill: white;" prefWidth="90.0" text="GO BACK" />
   </children>
</AnchorPane>
